{
  "effortLevel": "xhigh",
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "args": [
              "/Users/manish/.claude/session-continuity/hooks/precompact_snapshot.py"
            ],
            "command": "python3",
            "statusMessage": "Saving session continuity snapshot",
            "timeout": 20,
            "type": "command"
          }
        ],
        "matcher": "manual|auto"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "args": [
              "/Users/manish/.claude/session-continuity/hooks/sessionstart_compact_reinject.py"
            ],
            "command": "python3",
            "statusMessage": "Restoring compaction anchor",
            "timeout": 20,
            "type": "command"
          }
        ],
        "matcher": "compact"
      },
      {
        "hooks": [
          {
            "args": [
              "/Users/manish/.claude/session-continuity/hooks/sessionstart_clear_hint.py"
            ],
            "command": "python3",
            "statusMessage": "Checking for a task handoff",
            "timeout": 20,
            "type": "command"
          }
        ],
        "matcher": "clear"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "printf '\\a' >> /dev/tty 2>/dev/null || printf '\\a'",
            "type": "command"
          }
        ]
      }
    ]
  },
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm lint)",
      "Bash(pnpm test)",
      "Bash(pnpm build)",
      "Bash(pnpm typecheck)",
      "Bash(npm install)",
      "Bash(npm run lint:*)",
      "Bash(npm run ready:*)",
      "Bash(npm run test:*)",
      "Bash(npm run build:*)",
      "Bash(npm run quality:*)",
      "Bash(npm run typecheck:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(head:*)",
      "Bash(cd:*)",
      "Bash(tail:*)",
      "Bash(git log:*)"
    ],
    "defaultMode": "bypassPermissions",
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git reset --hard)",
      "Bash(git clean -fd *)",
      "Bash(vercel --prod *)",
      "Bash(supabase db push *)",
      "Bash(supabase db reset *)",
      "Bash(terraform destroy *)"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "statusLine": {
    "command": "sh ~/.claude/statusline-command.sh",
    "type": "command"
  },
  "theme": "dark",
  "voice": {
    "enabled": false,
    "mode": "hold"
  },
  "voiceEnabled": false
}
